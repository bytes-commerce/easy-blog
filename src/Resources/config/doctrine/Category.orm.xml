<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="https://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="BytesCommerce\EasyBlog\Entity\Category" table="bytes_commerce_blog_category">
        <indexes>
            <index name="idx_slug" columns="slug"/>
            <index name="idx_parent_id" columns="parent_id"/>
            <index name="idx_sort_order" columns="sort_order"/>
        </indexes>

        <unique-constraints>
            <unique-constraint name="uniq_slug" columns="slug"/>
        </unique-constraints>

        <field name="id" type="integer" id="true">
            <generator strategy="IDENTITY"/>
        </field>

        <field name="created_at" type="datetime_immutable" column="created_at"/>
        <field name="updated_at" type="datetime_immutable" column="updated_at"/>
        <field name="seoTitle" type="string" column="seo_title" nullable="true"/>
        <field name="seoDescription" type="string" column="seo_description" nullable="true"/>
        <field name="seoKeywords" type="string" column="seo_keywords" nullable="true"/>
        <field name="name" type="text" column="name"/>
        <field name="slug" type="string" column="slug"/>
        <field name="description" type="text" column="description" nullable="true"/>
        <field name="bottom_description" type="text" column="bottom_description" nullable="true"/>
        <field name="sort_order" type="integer" column="sort_order" nullable="true"/>
        <field name="access_counter" type="integer" column="access_counter" nullable="true"/>

        <many-to-one field="parent" target-entity="BytesCommerce\EasyBlog\Entity\Category" inversed-by="children">
            <join-column name="parent_id" referenced-column-name="id" on-delete="SET NULL"/>
        </many-to-one>

        <one-to-many field="children" target-entity="BytesCommerce\EasyBlog\Entity\Category" mapped-by="parent"/>

        <many-to-many field="posts" target-entity="BytesCommerce\EasyBlog\Entity\Post" mapped-by="categories"/>
    </entity>

</doctrine-mapping>
