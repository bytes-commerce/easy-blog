<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="https://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="BytesCommerce\EasyBlog\Entity\Post" table="bytes_commerce_blog_post">
        <indexes>
            <index name="idx_slug" columns="slug"/>
            <index name="idx_created_at" columns="created_at"/>
        </indexes>

        <unique-constraints>
            <unique-constraint name="uniq_slug" columns="slug"/>
        </unique-constraints>

        <id name="id" type="integer" column="id">
            <generator strategy="IDENTITY"/>
        </id>

        <field name="created_at" type="datetime_immutable" column="created_at"/>
        <field name="updated_at" type="datetime_immutable" column="updated_at"/>
        <field name="name" type="string" column="name"/>
        <field name="slug" type="string" column="slug"/>
        <field name="content" type="text" column="content"/>
        <field name="image" type="string" column="image" nullable="true"/>
        <field name="excerpt" type="text" column="excerpt" nullable="true"/>
        <field name="credits" type="text" column="credits" nullable="true"/>
        <field name="access_counter" type="integer" column="access_counter" nullable="true"/>

        <many-to-many field="categories" target-entity="BytesCommerce\EasyBlog\Entity\Category" inversed-by="posts">
            <join-table name="bytes_commerce_blog_post_category">
                <join-columns>
                    <join-column name="post_id" referenced-column-name="id" on-delete="CASCADE"/>
                </join-columns>
                <inverse-join-columns>
                    <join-column name="category_id" referenced-column-name="id" on-delete="CASCADE"/>
                </inverse-join-columns>
            </join-table>
        </many-to-many>

        <one-to-many field="faqs" target-entity="BytesCommerce\EasyBlog\Entity\Faq" mapped-by="post"/>
    </entity>

</doctrine-mapping>
